{
  "expo": {
    "name": "StackRate",
    "slug": "StackRate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/stackrate.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
   "android": {
  "package": "com.lawrencesaludes.stackrate",
  "adaptiveIcon": {
    "foregroundImage": "./assets/adaptive-icon.png",
    "backgroundColor": "#ffffff"
  },
  "edgeToEdgeEnabled": true,
  "predictiveBackGestureEnabled": false
},
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e45b5d9-6cf9-481a-adb2-d11df3f86a1e"
      }
    }
  }
}
